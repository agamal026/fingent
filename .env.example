# =============================================================================
# Environment variables for the Finance Automation Sandbox
# Copy this file to .env and fill in real values before running setup.sh
# NEVER commit .env to version control.
# =============================================================================

# Database connection string for the synthetic GL database (SQLite or Postgres)
DB_CONNECTION_STRING=sqlite:./data/finance.db

# Webhook URL that receives HITL approval requests
APPROVAL_WEBHOOK_URL=https://your-supervisor-webhook.example.com/approve

# Bearer token for authenticating outbound webhook calls
WEBHOOK_SECRET=replace-with-a-strong-random-secret

# Directory where incoming vendor invoice PDFs are deposited
INVOICE_INBOX_PATH=./inbox/invoices

# Month-end reconciliation thresholds
MATERIALITY_THRESHOLD=1000
VARIANCE_THRESHOLD=20
