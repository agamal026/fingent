{
  "version": "1.0",
  "jobs": [
    {
      "id": "ap-invoice-nightly",
      "description": "Process incoming AP invoices nightly",
      "cron": "0 2 * * *",
      "skill": "ap-invoice-pipeline",
      "enabled": true,
      "idempotent": true,
      "precheck": {
        "type": "directory-not-empty",
        "path": "./inbox/invoices"
      },
      "timeout": 3600,
      "retryOnFailure": false
    },
    {
      "id": "monthly-close",
      "description": "Run month-end reconciliation on the last day of each month at 2 AM",
      "cron": "0 2 28-31 * *",
      "skill": "monthly-close",
      "enabled": true,
      "idempotent": true,
      "precheck": {
        "type": "period-not-closed",
        "configPath": "./config/periods.json"
      },
      "timeout": 7200,
      "retryOnFailure": false
    }
  ]
}
